<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Talent Ai" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Talent Ai">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>
    <%= favicon_link_tag asset_path('favicon-96x96.png'), sizes: "96x96" %>
    <%= favicon_link_tag asset_path('favicon.svg'), type: "image/svg+xml" %>
    <%= favicon_link_tag asset_path('favicon.ico') %>
    <%= favicon_link_tag asset_path('apple-touch-icon.png'), sizes: "180x180" %>
    <%= favicon_link_tag asset_path('site.webmanifest'), rel: "manifest", type: "application/manifest+json" %>

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script src="https://js.puter.com/v2/" defer></script>
  </head>

  <body>
    <%= render "shared/flashes" %>

    <%= link_to "Skip to main content", "#main-content", class: "visually-hidden-focusable" %>
    <header>
      <%= render "shared/navbar" %> <!-- 👈 Add this for navbar -->
    </header>

    <main id="main-content">
      <%= yield %>
    </main>
  </body>
</html>
