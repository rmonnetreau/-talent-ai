  <div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-4">
      <div class="card">
        <div class="card-body">
          <% if @profile %>
            <h1><%= @profile.first_name.capitalize %> <%= @profile.last_name.capitalize %></h1>

            <div class="profile-details">
              <% if @profile.cv.attached? %>
                <p>
                  <strong>CV :</strong>
                  <%= link_to "Télécharger le CV", rails_blob_path(@profile.cv, disposition: "attachment"), class: "btn btn-secondary btn-sm" %>
                </p>
              <% else %>
                <p>Aucun CV n'a encore été ajouté.</p>
              <% end %>
            </div>

            <%= link_to "Modifier mon profil", edit_profile_path, class: "btn btn-primary" %>

          <% else %>
            <p>Vous n'avez pas encore de profil.</p>
            <%= link_to "Créer mon profil", new_profile_path, class: "btn btn-primary" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
