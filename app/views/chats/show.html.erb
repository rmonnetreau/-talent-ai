<div class="chat-show">
  <div class="chat-header">
    <div class="chat-header-title">
      <h1><%= @chat.title %>, pour <%= @interview.job_title %></h1>
      <p class="chat-subtitle">Recruteur <%= @chat_role.title %></p>
    </div>
      <%= button_to "Générer mes feedbacks", chat_feedbacks_path(@chat), class: "btn btn-success" %>
  </div>

  <div class="chat-module-card">
    <% last_assistant = @chat.messages.select { |m| m.role == "assistant" }.last %>
    <% @chat.messages.each do |message| %>
      <% is_assistant = message.role == "assistant" %>
      <div class="chat-module-messages d-flex flex-column mb-4 <%= is_assistant ? "align-items-start" : "align-items-end" %>"
        <%= is_assistant ? "data-controller=tts data-tts-autoplay-value=#{message == last_assistant}" : "" %>>
        <span><%= is_assistant ? message.role : "Vous" %></span>
        <p class="<%= is_assistant ? "" : "light" %>">
          <%= raw(markdown(message.content)) %>
        </p>
      </div>
    <% end %>

    <%= simple_form_for [@chat, @message] do |f| %>
      <%= f.input :content, label: "Répondre", required: true, placeholder: "Ecris ta réponse" %>
      <%= f.button :submit, 'Submit', class: 'btn btn-primary' %>
    <% end %>
    </div>
  </div>
</div>
<div id="bottom"></div>
