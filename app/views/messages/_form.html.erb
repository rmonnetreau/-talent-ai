<%= simple_form_for [chat, message],
       html: { data: { controller: "speech" } } do |f| %>
     <%= f.input :content,
       label: "Répondre",
       required: true,
       placeholder: "Écris ta réponse",
       input_html: {
         data: { speech_target: "input" }
       } %>
     <div class="chat-form-actions">
       <button type="button"
               class="mic-btn"
               data-action="click->speech#toggle"
               data-speech-target="button">
         🎙️ Dicter
       </button>
       <%= f.button :submit, "Submit", class: "btn btn-primary" %>
     </div>
   <% end %>
