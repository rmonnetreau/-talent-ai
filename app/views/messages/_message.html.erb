<% is_assistant = message.role == "assistant" %>
<% last_assistant ||= nil %>
<div id="<%= dom_id(message) %>" class="chat-module-messages d-flex flex-column mb-4 <%= is_assistant ? "align-items-start" : "align-items-end" %>"
     <% if is_assistant %>
       data-controller="tts"
       data-tts-autoplay-value="<%= message == last_assistant %>"
       data-tts-chat-id-value="<%= message.chat_id %>"
       data-tts-message-id-value="<%= message.id %>"
     <% end %>>

  <span><%= is_assistant ? message.role : "Vous" %></span>
  <div class="message-body <%= is_assistant ? "" : "light" %>">
    <%= raw(markdown(message.content)) %>
  </div>
</div>
