<% is_assistant = message.role == "assistant" %>
<div class="chat-module-messages d-flex flex-column mb-4 <%= is_assistant ? "align-items-start" : "align-items-end" %>" <%= is_assistant ? "data-controller=tts data-tts-autoplay-value=#{message == last_assistant}" : "" %>>

  <span><%= is_assistant ? message.role : "Vous" %></span>
  <div class="message-body <%= is_assistant ? "" : "light" %>">
    <%= raw(markdown(message.content)) %>
  </div>
</div>
