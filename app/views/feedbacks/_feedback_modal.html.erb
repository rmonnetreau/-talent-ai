<% interview.chats.joins(:feedback).each_with_index do |chat| %>
  <% feedback = chat.feedback %>

  <div id="feedback-modal-<%= feedback.id %>" class="modal-overlay" hidden>
    <div class="modal-box modal-box--wide">

      <div class="modal-header">
        <div>
          <h2 class="modal-title">Feedback — <%= chat.title %></h2>
          <p class="modal-subtitle">
            <%= interview.job_title %> · <%= chat.chat_role.title %> · <%= l(chat.created_at.to_date, format: :short) %> · <%= pluralize(chat.messages.count, "échange", "échanges") %>
          </p>
        </div>
        <button class="modal-close" onclick="closeModal('<%= feedback.id %>')" aria-label="Fermer">×</button>
      </div>

      <div class="modal-grid">

        <div class="modal-section">
          <p class="modal-section-title">Dashboard</p>

          <div class="modal-score-row">
            <div class="modal-score-circle" style="--score: <%= feedback.global_score %>%">
              <span class="modal-score-num"><%= feedback.global_score %></span>
            </div>
            <div>
              <p class="modal-score-label">Score Global</p>
              <p class="modal-score-advice">
                <%= case feedback.global_score
                    when 85..100 then "Excellent niveau"
                    when 70..84  then "Niveau Senior"
                    when 50..69  then "Bonne base à consolider"
                    else              "Des axes à travailler"
                    end %>
              </p>
            </div>
          </div>

          <% if feedback.best_answer.present? %>
            <div class="modal-answer modal-answer--green">
              <p class="modal-answer-label">💬 Meilleure réponse</p>
              <div class="modal-answer-text"><%= markdown(feedback.best_answer.gsub(/###.*?\n/, '')) %></div>
            </div>
          <% end %>

          <% if feedback.worst_answer.present? %>
            <div class="modal-answer modal-answer--red">
              <p class="modal-answer-label">⚠️ Réponse la plus faible</p>
              <div class="modal-answer-text"><%= markdown(feedback.worst_answer.gsub(/###.*?\n/, '')) %></div>
            </div>
          <% end %>
        </div>

        <div class="modal-section">
          <p class="modal-section-title">Debrief</p>

          <% if feedback.strengths.present? %>
            <div>
              <p class="modal-debrief-label">👍 Points Forts</p>
              <div class="feedback-content--green">
                <%= markdown(feedback.strengths.gsub(/###.*?\n/, '')) %>
              </div>
            </div>
          <% end %>

          <% if feedback.weaknesses.present? %>
            <div>
              <p class="modal-debrief-label">🎯 Axes d'Amélioration</p>
              <div class="feedback-content--orange">
                <%= markdown(feedback.weaknesses.gsub(/###.*?\n/, '')) %>
              </div>
            </div>
          <% end %>
        </div>

        <div class="modal-section">
          <p class="modal-section-title">Plan d'action</p>

          <% if feedback.priority_advice.present? %>
            <div>
              <p class="modal-debrief-label">🛠️ Conseil Prioritaire</p>
              <div class="feedback-content--amber">
                <%= markdown(feedback.priority_advice.gsub(/###.*?\n/, '')) %>
              </div>
            </div>
          <% end %>

          <% if feedback.recommended_method.present? %>
            <div>
              <p class="modal-debrief-label">📚 Méthode Recommandée</p>
              <div class="feedback-content--blue">
                <%= markdown(feedback.recommended_method.gsub(/###.*?\n/, '')) %>
              </div>
            </div>
          <% end %>
        </div>

      </div>

      <div class="modal-footer">
        <button class="btn btn-outline-secondary btn-sm" onclick="closeModal('<%= feedback.id %>')">
          Rejouer l'exercice
        </button>
        <%= link_to chat_path(chat), class: "btn btn-sm", style: "background: #1e3e4a; color: white;" do %>
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          Voir la conversation
        <% end %>
      </div>

    </div>
  </div>
<% end %>
