<% has_finished_chats = interview.chats.joins(:feedback).exists? %>
<% has_ongoing_chats = interview.chats.where.missing(:feedback).exists? %>

<div class="interview-card"
     data-interviews-filter-target="card"
     data-title="<%= interview.job_title.to_s.downcase %>"
     data-description="<%= interview.job_description.to_s.downcase %>"
     data-status="<%= has_ongoing_chats ? "ongoing" : has_finished_chats ? "finished" : "empty" %>"
     data-created-at="<%= interview.created_at.to_i %>">
  <div class="interview-card-header">
    <div class="interview-card-meta">
      <h2 class="interview-card-title"><%= interview.job_title %></h2>
      <p class="interview-card-created">
        Créé le <%= l(interview.created_at.to_date, format: :long) %> · <%= pluralize(interview.chats.count, "simulation", "simulations") %>
      </p>
    </div>
    <div class="interview-card-actions">
      <%= link_to edit_interview_path(interview), class: "icon-btn", title: "Modifier" do %>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
          <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
        </svg>
      <% end %>
      <%= button_to interview_path(interview),
        method: :delete,
        class: "icon-btn text-danger",
        title: "Supprimer",
        form: { data: { turbo_confirm: "Supprimer cet entretien ?" } } do %>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="1.5"
            stroke-linecap="round" stroke-linejoin="round">
          <polyline points="3 6 5 6 21 6"/>
          <path d="M19 6l-1 14H6L5 6"/>
          <path d="M10 11v6"/>
          <path d="M14 11v6"/>
          <path d="M9 6V4h6v2"/>
        </svg>
      <% end %>
      <button class="icon-btn toggle-card" data-interview-id="<%= interview.id %>" title="Réduire">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="18 15 12 9 6 15"/>
        </svg>
      </button>
    </div>
  </div>

  <div class="interview-card-body" id="interview-body-<%= interview.id %>">
    <p class="interview-description">
      <%= truncate(interview.job_description, length: 300) %>
    </p>

    <% finished_chats = interview.chats.joins(:feedback).order(created_at: :asc) %>
    <% ongoing_chats = interview.chats.where.missing(:feedback).order(created_at: :asc) %>

    <% if finished_chats.any? %>
      <div class="chats-section">
        <p class="chats-section-label">Simulations terminées</p>
        <div class="chats-grid">
          <% finished_chats.each_with_index do |chat| %>
            <div class="chat-card finished" onclick="openModal('<%= chat.feedback.id %>')">
              <div class="chat-card-top">
                <span class="chat-card-title"><%= chat.title %></span>
                <div>
                  <span class="badge-feedback">✓ Feedback</span>
                </div>
              </div>
              <p class="chat-card-meta">
                <%= l(chat.created_at.to_date, format: :short) %> · <%= pluralize(chat.messages.count, "échange", "échanges") %>
              </p>
              <% if chat.feedback&.global_score %>
                <div class="chat-progress-row">
                  <div class="chat-progress-bar">
                    <div class="chat-progress-fill" style="width: <%= chat.feedback.global_score %>%"></div>
                  </div>
                  <span class="chat-score"><%= chat.feedback.global_score %> / 100</span>
                </div>
              <% end %>
              </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if ongoing_chats.any? || true %>
      <div class="chats-section">
        <p class="chats-section-label">En cours</p>
        <div class="chats-grid">
          <% ongoing_chats.each_with_index do |chat| %>
            <div class="chat-card ongoing">
              <div class="chat-card-top">
                <span class="chat-card-title"><%= chat.title %></span>
                <span class="badge-ongoing">⏱ En cours</span>
              </div>
              <p class="chat-card-meta">
                Repris le <%= l(chat.updated_at.to_date, format: :short) %> · <%= pluralize(chat.messages.count, "échange", "échanges") %>
              </p>
              <%= link_to "▷ Reprendre", chat_path(chat), class: "chat-resume-link" %>
            </div>
          <% end %>

          <%= link_to new_interview_chat_path(interview), class: "chat-card new-chat" do %>
            <span class="new-chat-icon">+</span>
            <span class="new-chat-label">Nouvelle simulation</span>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<%= render "feedbacks/feedback_modal", interview: interview %>
